#include <LiquidCrystal.h>

/* ---------------- LCD ---------------- */
LiquidCrystal lcd(7, 6, 5, 4, 3, 2);

/* ---------------- SENSOR PINS ---------------- */
#define MQ2       A0
#define LM35      A1
#define FLAME     A2
#define WATER     A3
#define VIBRATION 23

/* ---------------- LIMITS ---------------- */
#define GAS_LIMIT    200
#define TEMP_LIMIT   35
#define FLAME_LIMIT  150     //  Fire when value > 150
#define WATER_LIMIT  500

/* ---------------- PHONE NUMBER ---------------- */
String phoneNumber = "+919322963648";

/* ---------------- ALERT FLAGS ---------------- */
bool gasSent = false;
bool tempSent = false;
bool flameSent = false;
bool waterSent = false;
bool vibSent = false;

/* ==================================================
                SEND SMS FUNCTION (SIM900)
   ================================================== */
void sendSMS(String msg)
{
  Serial1.println("AT+CMGF=1");   // Text mode
  delay(1000);

  Serial1.print("AT+CMGS=\"");
  Serial1.print(phoneNumber);
  Serial1.println("\"");
  delay(1000);

  Serial1.println(msg);
  delay(1000);

  Serial1.write(26);  // CTRL+Z
  delay(5000);
}

/* ==================================================
                      SETUP
   ================================================== */
void setup()
{
  pinMode(VIBRATION, INPUT);

  lcd.begin(16, 2);
  lcd.clear();
  lcd.print("SMART MANHOLE");
  lcd.setCursor(0, 1);
  lcd.print("SYSTEM START");
  delay(2000);

  /* ---------- SERIAL MONITOR ---------- */
  Serial.begin(9600);

  /* ---------- GSM SERIAL (Mega Serial1) ---------- */
  Serial1.begin(9600);
  delay(8000);   // Wait for SIM900 network

  /* ---------- GSM BASIC INIT ---------- */
  Serial1.println("AT");
  delay(1000);

  Serial1.println("AT+CSQ");      // Signal check
  delay(1000);

  Serial1.println("AT+CREG?");    // Network registration
  delay(1000);

  /* Startup SMS */
  sendSMS("Smart Manhole System Started Successfully!");
}

/* ==================================================
                      LOOP
   ================================================== */
void loop()
{
  /* -------- READ SENSOR VALUES -------- */
  int gas = analogRead(MQ2);

  int tempRaw = analogRead(LM35);
  float temp = (tempRaw * 5.0 / 1023.0) * 100;

  int flame = analogRead(FLAME);

  int water = analogRead(WATER);

  int vibration = digitalRead(VIBRATION);

  /* ==================================================
                        GAS ALERT
     ================================================== */
  lcd.clear();
  if (gas > GAS_LIMIT)
  {
    lcd.print("GAS HIGH!");
    lcd.setCursor(0, 1);
    lcd.print("Value=");
    lcd.print(gas);

    if (!gasSent)
    {
      sendSMS("ALERT! Gas Level High in Manhole!");
      gasSent = true;
    }
  }
  else
  {
    gasSent = false;
    lcd.print("Gas Level:");
    lcd.setCursor(0, 1);
    lcd.print(gas);
  }
  delay(2500);

  /* ==================================================
                    TEMPERATURE ALERT
     ================================================== */
  lcd.clear();
  if (temp > TEMP_LIMIT)
  {
    lcd.print("TEMP HIGH!");
    lcd.setCursor(0, 1);
    lcd.print(temp);
    lcd.print("C");

    if (!tempSent)
    {
      sendSMS("ALERT! Temperature High in Manhole!");
      tempSent = true;
    }
  }
  else
  {
    tempSent = false;
    lcd.print("Temp:");
    lcd.setCursor(0, 1);
    lcd.print(temp);
    lcd.print("C");
  }
  delay(2500);

  /* ==================================================
                      FLAME ALERT (Fixed)
     ================================================== */
  lcd.clear();

  //  Your requirement: No flame = 0, Fire when >150
  if (flame > FLAME_LIMIT)
  {
    lcd.print("FIRE DETECTED!");
    lcd.setCursor(0, 1);
    lcd.print("Value=");
    lcd.print(flame);

    if (!flameSent)
    {
      sendSMS("ALERT! Fire Detected in Manhole!");
      flameSent = true;
    }
  }
  else
  {
    flameSent = false;
    lcd.print("No Fire");
    lcd.setCursor(0, 1);
    lcd.print("Flame=");
    lcd.print(flame);
  }
  delay(2500);

  /* ==================================================
                      WATER ALERT
     ================================================== */
  lcd.clear();
  if (water > WATER_LIMIT)
  {
    lcd.print("WATER HIGH!");
    lcd.setCursor(0, 1);
    lcd.print("Level=");
    lcd.print(water);

    if (!waterSent)
    {
      sendSMS("ALERT! Water Level High in Manhole!");
      waterSent = true;
    }
  }
  else
  {
    waterSent = false;
    lcd.print("Water Level:");
    lcd.setCursor(0, 1);
    lcd.print(water);
  }
  delay(2500);

  /* ==================================================
                    VIBRATION ALERT
     ================================================== */
  lcd.clear();
  lcd.print("Vibration:");

  lcd.setCursor(0, 1);
  if (vibration == HIGH)
  {
    lcd.print("Detected!");

    if (!vibSent)
    {
      sendSMS("ALERT! Vibration Detected in Manhole!");
      vibSent = true;
    }
  }
  else
  {
    vibSent = false;
    lcd.print("Normal");
  }

  delay(2500);
}

